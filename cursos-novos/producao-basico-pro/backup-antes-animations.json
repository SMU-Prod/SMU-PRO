        "html": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>SMU PRO — Show × Corporativo</title>\n<script src=\"https://unpkg.com/react@18/umd/react.production.min.js\"></script>\n<script src=\"https://unpkg.com/react-dom@18/umd/react-dom.production.min.js\"></script>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<script src=\"https://unpkg.com/@babel/standalone/babel.min.js\"></script>\n<style>html,body{height:100%;margin:0;background:#0b1120}#root{height:100vh}</style>\n</head>\n<body>\n<script>/*SMU-ZOOM*/(function(){var z=1,sc=null,MIN=1,MAX=2.5,STEP=0.25;function wrap(){if(sc)return;sc=document.createElement('div');sc.id='smu-sc';sc.style.transformOrigin='0 0';[].slice.call(document.body.children).filter(function(el){return (el.id||'').indexOf('smu-')!==0;}).forEach(function(k){sc.appendChild(k);});document.body.insertBefore(sc,document.body.firstChild);document.documentElement.style.overflow='auto';document.body.style.overflow='auto';document.body.style.margin='0';}function apply(){if(!sc)wrap();sc.style.transform='scale('+z+')';var w=sc.offsetWidth,h=sc.offsetHeight;document.body.style.width=(z>1?(w*z)+'px':'');document.body.style.height=(z>1?(h*z)+'px':'');var l=document.getElementById('smu-zl');if(l)l.textContent=Math.round(z*100)+'%';}function ui(){if(document.getElementById('smu-zoom'))return;var b=document.createElement('div');b.id='smu-zoom';b.style.cssText='position:fixed;left:10px;bottom:10px;z-index:99999;display:flex;align-items:center;gap:5px;background:#0e1420;border:1px solid #2c3340;border-radius:22px;padding:5px 8px;box-shadow:0 2px 10px rgba(0,0,0,.4);font-family:system-ui,sans-serif';function mk(t){var x=document.createElement('button');x.textContent=t;x.style.cssText='width:32px;height:32px;border-radius:50%;border:1px solid #2c3340;background:#171c26;color:#e5e7eb;font-size:18px;cursor:pointer;padding:0;line-height:1';return x;}var ic=document.createElement('span');ic.textContent='\\U0001F50D';ic.style.fontSize='14px';var mi=mk('−'),lab=document.createElement('span'),pl=mk('+');lab.id='smu-zl';lab.style.cssText='font-size:12px;color:#cbd5e1;min-width:44px;text-align:center;cursor:pointer';lab.textContent='100%';b.appendChild(ic);b.appendChild(mi);b.appendChild(lab);b.appendChild(pl);document.body.appendChild(b);mi.onclick=function(){z=Math.max(MIN,Math.round((z-STEP)*100)/100);apply();};pl.onclick=function(){z=Math.min(MAX,Math.round((z+STEP)*100)/100);apply();};lab.onclick=function(){z=1;apply();};}if(document.readyState!=='loading')ui();else document.addEventListener('DOMContentLoaded',ui);})();</script>\n\n<div id=\"root\"></div>\n<script type=\"text/babel\">\nconst {useState} = React;\n\n// tipo: 'show' | 'corp' | 'ambos'\nconst ITENS=[\n  {l:'PA potente com subgrave forte', tipo:'show',  e:'🔊', why:'Música ao vivo pede pressão sonora e grave.'},\n  {l:'Microfone de lapela para o palestrante', tipo:'corp', e:'🎙️', why:'Palestra/fala: lapela libera as mãos.'},\n  {l:'Backline (bateria, amplificadores de palco)', tipo:'show', e:'🥁', why:'Banda toca instrumentos no palco.'},\n  {l:'Projeção de slides / telão de apresentação', tipo:'corp', e:'📊', why:'Conteúdo visual da palestra/empresa.'},\n  {l:'Iluminação cênica (moving heads, cores)', tipo:'show', e:'💡', why:'Clima e espetáculo do show.'},\n  {l:'Tradução simultânea / cabines', tipo:'corp', e:'🌐', why:'Evento corporativo com público internacional.'},\n  {l:'Retorno / monitor de palco para os músicos', tipo:'show', e:'🎚️', why:'Banda precisa se ouvir no palco.'},\n  {l:'Gravação e transmissão (streaming) da palestra', tipo:'corp', e:'🎥', why:'Conteúdo corporativo é registrado/transmitido.'},\n  {l:'Microfone sem fio de mão e boa cobertura de voz', tipo:'ambos', e:'🎤', why:'Tanto o cantor quanto o palestrante usam.'},\n  {l:'Energia dimensionada e aterramento', tipo:'ambos', e:'⚡', why:'Todo evento precisa de energia segura.'},\n];\n\nconst ROTULO={show:'Show',corp:'Corporativo',ambos:'Ambos'};\n\nfunction Widget(){\n  const [phase,setPhase]=useState('intro');\n  const [i,setI]=useState(0);\n  const [score,setScore]=useState(0);\n  const [res,setRes]=useState(null);\n  const it=ITENS[i];\n\n  const begin=()=>{ setI(0); setScore(0); setRes(null); setPhase('play'); };\n  const responder=(tipo)=>{ const acerto=tipo===it.tipo; setScore(s=>s+(acerto?100:0));\n    setRes({acerto, msg:(acerto?'✅ Isso! ':'❌ Na verdade é '+ROTULO[it.tipo]+'. ')+it.why}); };\n  const prox=()=>{ if(i>=ITENS.length-1){ setPhase('done'); return; } setI(i+1); setRes(null); };\n\n  if(phase==='intro'){\n    return (\n      <div className=\"w-full h-full flex flex-col items-center justify-center text-center px-6\" style={{background:'#0b1120'}}>\n        <div className=\"text-amber-400 text-xs tracking-[0.3em] mb-2\">SMU PRO · PRODUÇÃO BÁSICO</div>\n        <div className=\"text-white text-2xl font-bold mb-3\">🎯 Show × Corporativo</div>\n        <div className=\"text-slate-300 text-sm max-w-md mb-1\">Pra um técnico, a base é a mesma — mas a <b className=\"text-amber-300\">necessidade</b> muda com o tipo de cliente. <b className=\"text-fuchsia-300\">Show</b> pede PA, palco e backline; <b className=\"text-sky-300\">Corporativo</b> pede fala clara, projeção e registro.</div>\n        <div className=\"text-slate-300 text-sm max-w-md mb-5\">Para cada necessidade, escolha: <b>Show</b>, <b>Corporativo</b> ou <b>Ambos</b>.</div>\n        <button onClick={begin} className=\"px-7 py-3 rounded-xl bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold text-base transition\">▶ Começar</button>\n        <div className=\"text-slate-500 text-xs mt-4\">Saber ler o cliente é meio caminho do orçamento certo.</div>\n      </div>\n    );\n  }\n  if(phase==='done'){\n    return (\n      <div className=\"w-full h-full flex flex-col items-center justify-center text-center px-6\" style={{background:'#0b1120'}}>\n        <div className=\"text-amber-400 text-sm mb-1\">Briefing concluído</div>\n        <div className=\"text-white text-3xl font-bold mb-1\">{score} pontos</div>\n        <div className=\"text-slate-400 text-sm mb-5\">{score>=800?'Lê o cliente de primeira! 🥇':score>=500?'Bom faro de produção. 👏':'Treine: Show=palco/PA, Corporativo=fala/projeção.'}</div>\n        <button onClick={begin} className=\"px-7 py-3 rounded-xl bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold transition\">↻ Jogar de novo</button>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"w-full h-full flex flex-col p-3 gap-3\" style={{background:'#0b1120'}}>\n      <div className=\"flex justify-between items-center text-xs\">\n        <span className=\"text-slate-200 font-bold\">PONTOS {score}</span>\n        <span className=\"text-amber-400 font-bold\">{i+1}/{ITENS.length}</span>\n      </div>\n\n      <div className=\"flex-1 min-h-0 flex flex-col items-center justify-center text-center\">\n        <div className=\"text-5xl mb-3\">{it.e}</div>\n        <div className=\"text-white text-lg font-bold px-4 leading-snug\">{it.l}</div>\n        <div className=\"text-slate-500 text-xs mt-2\">Esse pedido é mais de qual cliente?</div>\n      </div>\n\n      {res ? (\n        <div className=\"rounded-lg px-3 py-2 text-center\" style={{background:res.acerto?'rgba(16,185,129,0.12)':'rgba(239,68,68,0.12)'}}>\n          <div className=\"text-slate-200 text-xs\">{res.msg}</div>\n          <button onClick={prox} className=\"mt-1 px-5 py-1.5 rounded-lg bg-amber-500 hover:bg-amber-400 text-slate-900 text-sm font-bold\">{i>=ITENS.length-1?'Ver resultado':'Próximo →'}</button>\n        </div>\n      ) : (\n        <div className=\"grid grid-cols-3 gap-2\">\n          <button onClick={()=>responder('show')}  className=\"py-3 rounded-lg bg-fuchsia-700 hover:bg-fuchsia-600 text-white font-bold text-sm transition\">🎶 Show</button>\n          <button onClick={()=>responder('corp')}  className=\"py-3 rounded-lg bg-sky-700 hover:bg-sky-600 text-white font-bold text-sm transition\">🏢 Corporativo</button>\n          <button onClick={()=>responder('ambos')} className=\"py-3 rounded-lg bg-slate-600 hover:bg-slate-500 text-white font-bold text-sm transition\">🔁 Ambos</button>\n        </div>\n      )}\n    </div>\n  );\n}\n\nReactDOM.createRoot(document.getElementById('root')).render(<Widget/>);\n</script>\n</body>\n</html>\n"
      }
