        "html": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>SMU PRO — Run of Show</title>\n<script src=\"https://unpkg.com/react@18/umd/react.production.min.js\"></script>\n<script src=\"https://unpkg.com/react-dom@18/umd/react-dom.production.min.js\"></script>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<script src=\"https://unpkg.com/@babel/standalone/babel.min.js\"></script>\n<style>html,body{height:100%;margin:0;background:#0b1120}#root{height:100vh}</style>\n</head>\n<body>\n<script>/*SMU-ZOOM*/(function(){var z=1,sc=null,MIN=1,MAX=2.5,STEP=0.25;function wrap(){if(sc)return;sc=document.createElement('div');sc.id='smu-sc';sc.style.transformOrigin='0 0';[].slice.call(document.body.children).filter(function(el){return (el.id||'').indexOf('smu-')!==0;}).forEach(function(k){sc.appendChild(k);});document.body.insertBefore(sc,document.body.firstChild);document.documentElement.style.overflow='auto';document.body.style.overflow='auto';document.body.style.margin='0';}function apply(){if(!sc)wrap();sc.style.transform='scale('+z+')';var w=sc.offsetWidth,h=sc.offsetHeight;document.body.style.width=(z>1?(w*z)+'px':'');document.body.style.height=(z>1?(h*z)+'px':'');var l=document.getElementById('smu-zl');if(l)l.textContent=Math.round(z*100)+'%';}function ui(){if(document.getElementById('smu-zoom'))return;var b=document.createElement('div');b.id='smu-zoom';b.style.cssText='position:fixed;left:10px;bottom:10px;z-index:99999;display:flex;align-items:center;gap:5px;background:#0e1420;border:1px solid #2c3340;border-radius:22px;padding:5px 8px;box-shadow:0 2px 10px rgba(0,0,0,.4);font-family:system-ui,sans-serif';function mk(t){var x=document.createElement('button');x.textContent=t;x.style.cssText='width:32px;height:32px;border-radius:50%;border:1px solid #2c3340;background:#171c26;color:#e5e7eb;font-size:18px;cursor:pointer;padding:0;line-height:1';return x;}var ic=document.createElement('span');ic.textContent='\\U0001F50D';ic.style.fontSize='14px';var mi=mk('−'),lab=document.createElement('span'),pl=mk('+');lab.id='smu-zl';lab.style.cssText='font-size:12px;color:#cbd5e1;min-width:44px;text-align:center;cursor:pointer';lab.textContent='100%';b.appendChild(ic);b.appendChild(mi);b.appendChild(lab);b.appendChild(pl);document.body.appendChild(b);mi.onclick=function(){z=Math.max(MIN,Math.round((z-STEP)*100)/100);apply();};pl.onclick=function(){z=Math.min(MAX,Math.round((z+STEP)*100)/100);apply();};lab.onclick=function(){z=1;apply();};}if(document.readyState!=='loading')ui();else document.addEventListener('DOMContentLoaded',ui);})();</script>\n\n<div id=\"root\"></div>\n<script type=\"text/babel\">\nconst {useState} = React;\n\nconst ETAPAS=[\n  {t:'08:00', l:'Descarga / Load-in', e:'🚚'},\n  {t:'09:00', l:'Montagem de estrutura (rigging/treliça)', e:'🏗️'},\n  {t:'11:00', l:'Montagem de som e luz', e:'🔊'},\n  {t:'14:00', l:'Energia e testes gerais', e:'⚡'},\n  {t:'16:00', l:'Passagem de som (soundcheck)', e:'🎤'},\n  {t:'18:00', l:'Liberação da casa / portas abrem', e:'🚪'},\n  {t:'20:00', l:'Show / evento', e:'🎶'},\n  {t:'23:00', l:'Encerramento', e:'🏁'},\n  {t:'23:30', l:'Desmontagem / Load-out', e:'📦'},\n];\n\nfunction shuffle(a){ a=a.slice(); for(let i=a.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); [a[i],a[j]]=[a[j],a[i]]; } return a; }\n\nfunction Widget(){\n  const [phase,setPhase]=useState('intro');\n  const [pool,setPool]=useState([]);     // indices restantes (embaralhados)\n  const [done,setDone]=useState([]);      // indices colocados em ordem\n  const [score,setScore]=useState(0);\n  const [wrong,setWrong]=useState(-1);\n  const [streak,setStreak]=useState(0);\n\n  const begin=()=>{ setPool(shuffle(ETAPAS.map((_,i)=>i))); setDone([]); setScore(0); setStreak(0); setWrong(-1); setPhase('play'); };\n  const pick=(idx)=>{\n    const esperado=done.length;          // próxima etapa esperada é a de índice = quantas já colocou\n    if(idx===esperado){\n      setDone([...done,idx]); setPool(pool.filter(p=>p!==idx)); setWrong(-1);\n      const ns=streak+1; setStreak(ns); setScore(s=>s+50+ (ns>=3?20:0));\n      if(done.length+1===ETAPAS.length) setTimeout(()=>setPhase('done'),500);\n    }else{\n      setWrong(idx); setStreak(0); setScore(s=>Math.max(0,s-10));\n      setTimeout(()=>setWrong(-1),500);\n    }\n  };\n\n  if(phase==='intro'){\n    return (\n      <div className=\"w-full h-full flex flex-col items-center justify-center text-center px-6\" style={{background:'#0b1120'}}>\n        <div className=\"text-amber-400 text-xs tracking-[0.3em] mb-2\">SMU PRO · PRODUÇÃO BÁSICO</div>\n        <div className=\"text-white text-2xl font-bold mb-3\">📋 Run of Show</div>\n        <div className=\"text-slate-300 text-sm max-w-md mb-1\">O <b className=\"text-amber-300\">Run of Show</b> é a linha do tempo do evento. Cada etapa tem sua hora e sua ordem — pular uma fase quebra tudo.</div>\n        <div className=\"text-slate-300 text-sm max-w-md mb-5\">Monte o dia na <b>ordem certa</b>, do load-in à desmontagem. Clique nas etapas na sequência correta.</div>\n        <button onClick={begin} className=\"px-7 py-3 rounded-xl bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold text-base transition\">▶ Montar o dia</button>\n        <div className=\"text-slate-500 text-xs mt-4\">Sequência sem erro = bônus. Etapa errada = perde pontos.</div>\n      </div>\n    );\n  }\n  if(phase==='done'){\n    return (\n      <div className=\"w-full h-full flex flex-col items-center justify-center text-center px-6\" style={{background:'#0b1120'}}>\n        <div className=\"text-amber-400 text-sm mb-1\">Evento montado do início ao fim</div>\n        <div className=\"text-white text-3xl font-bold mb-1\">{score} pontos</div>\n        <div className=\"text-slate-400 text-sm mb-5\">{score>=450?'Produtor de mão cheia! 🥇':score>=300?'Boa, o dia fluiu. 👏':'Revise a ordem: cada fase prepara a próxima.'}</div>\n        <button onClick={begin} className=\"px-7 py-3 rounded-xl bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold transition\">↻ Jogar de novo</button>\n      </div>\n    );\n  }\n\n  const prox=done.length+1;\n  return (\n    <div className=\"w-full h-full flex flex-col p-3 gap-2\" style={{background:'#0b1120'}}>\n      <div className=\"flex justify-between items-center text-xs\">\n        <span className=\"text-slate-200 font-bold\">PONTOS {score}</span>\n        <span className=\"text-amber-400 font-bold\">{done.length}/{ETAPAS.length} etapas</span>\n      </div>\n\n      {/* linha do tempo montada */}\n      <div className=\"rounded-lg p-2 overflow-auto\" style={{background:'#070b16', maxHeight:'42%'}}>\n        {done.length===0 && <div className=\"text-slate-600 text-[11px] text-center py-2\">A linha do tempo aparece aqui…</div>}\n        {done.map((i,k)=>(\n          <div key={i} className=\"flex items-center gap-2 text-xs py-0.5\">\n            <span className=\"text-amber-300 font-bold tabular-nums w-10\">{ETAPAS[i].t}</span>\n            <span>{ETAPAS[i].e}</span>\n            <span className=\"text-slate-200\">{ETAPAS[i].l}</span>\n          </div>\n        ))}\n      </div>\n\n      <div className=\"text-center text-slate-400 text-[12px]\">Qual é a <b className=\"text-amber-300\">{prox}ª</b> etapa?</div>\n\n      {/* pool de etapas restantes */}\n      <div className=\"flex-1 min-h-0 overflow-auto grid grid-cols-1 gap-1.5\">\n        {pool.map(i=>(\n          <button key={i} onClick={()=>pick(i)}\n            className=\"flex items-center gap-2 rounded-lg px-3 py-2 text-left text-xs font-medium transition border\"\n            style={{background: wrong===i?'rgba(239,68,68,0.25)':'#0f172a', borderColor: wrong===i?'#ef4444':'#334155', color:'#e2e8f0'}}>\n            <span className=\"text-base\">{ETAPAS[i].e}</span>{ETAPAS[i].l}\n          </button>\n        ))}\n      </div>\n    </div>\n  );\n}\n\nReactDOM.createRoot(document.getElementById('root')).render(<Widget/>);\n</script>\n</body>\n</html>\n"
      }
