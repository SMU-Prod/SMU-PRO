          "html": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>SMU PRO — Endereçamento DMX</title>\n<script src=\"https://unpkg.com/react@18/umd/react.production.min.js\"></script>\n<script src=\"https://unpkg.com/react-dom@18/umd/react-dom.production.min.js\"></script>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<script src=\"https://unpkg.com/@babel/standalone/babel.min.js\"></script>\n<style>html,body{height:100%;margin:0;background:#0b1120}#root{height:100vh}</style>\n</head>\n<body>\n<script>/*SMU-ZOOM*/(function(){var z=1,sc=null,MIN=1,MAX=2.5,STEP=0.25;function wrap(){if(sc)return;sc=document.createElement('div');sc.id='smu-sc';sc.style.transformOrigin='0 0';[].slice.call(document.body.children).filter(function(el){return (el.id||'').indexOf('smu-')!==0;}).forEach(function(k){sc.appendChild(k);});document.body.insertBefore(sc,document.body.firstChild);document.documentElement.style.overflow='auto';document.body.style.overflow='auto';document.body.style.margin='0';}function apply(){if(!sc)wrap();sc.style.transform='scale('+z+')';var w=sc.offsetWidth,h=sc.offsetHeight;document.body.style.width=(z>1?(w*z)+'px':'');document.body.style.height=(z>1?(h*z)+'px':'');var l=document.getElementById('smu-zl');if(l)l.textContent=Math.round(z*100)+'%';}function ui(){if(document.getElementById('smu-zoom'))return;var b=document.createElement('div');b.id='smu-zoom';b.style.cssText='position:fixed;left:10px;bottom:10px;z-index:99999;display:flex;align-items:center;gap:5px;background:#0e1420;border:1px solid #2c3340;border-radius:22px;padding:5px 8px;box-shadow:0 2px 10px rgba(0,0,0,.4);font-family:system-ui,sans-serif';function mk(t){var x=document.createElement('button');x.textContent=t;x.style.cssText='width:32px;height:32px;border-radius:50%;border:1px solid #2c3340;background:#171c26;color:#e5e7eb;font-size:18px;cursor:pointer;padding:0;line-height:1';return x;}var ic=document.createElement('span');ic.textContent='\\U0001F50D';ic.style.fontSize='14px';var mi=mk('−'),lab=document.createElement('span'),pl=mk('+');lab.id='smu-zl';lab.style.cssText='font-size:12px;color:#cbd5e1;min-width:44px;text-align:center;cursor:pointer';lab.textContent='100%';b.appendChild(ic);b.appendChild(mi);b.appendChild(lab);b.appendChild(pl);document.body.appendChild(b);mi.onclick=function(){z=Math.max(MIN,Math.round((z-STEP)*100)/100);apply();};pl.onclick=function(){z=Math.min(MAX,Math.round((z+STEP)*100)/100);apply();};lab.onclick=function(){z=1;apply();};}if(document.readyState!=='loading')ui();else document.addEventListener('DOMContentLoaded',ui);})();</script>\n\n<div id=\"root\"></div>\n<script type=\"text/babel\">\nconst {useState} = React;\n\n// cada round = um conjunto de fixtures com tamanhos (canais) diferentes\nconst ROUNDS = [\n  {meta:'Endereçe os 3 refletores sem conflito.', fx:[\n     {nome:'PAR LED 1', ch:4, cor:'#ef4444'},\n     {nome:'PAR LED 2', ch:4, cor:'#22c55e'},\n     {nome:'PAR LED 3', ch:4, cor:'#3b82f6'}]},\n  {meta:'Agora entrou um Moving (8 canais). Sem conflito.', fx:[\n     {nome:'PAR LED 1', ch:4, cor:'#ef4444'},\n     {nome:'PAR LED 2', ch:4, cor:'#22c55e'},\n     {nome:'Moving Head', ch:8, cor:'#e8e1d0'},\n     {nome:'PAR LED 3', ch:4, cor:'#3b82f6'}]},\n  {meta:'4 fixtures, tamanhos diferentes. Encaixe tudo sem sobrepor.', fx:[\n     {nome:'Wash 6ch', ch:6, cor:'#a855f7'},\n     {nome:'PAR 4ch', ch:4, cor:'#ef4444'},\n     {nome:'Beam 11ch', ch:11, cor:'#06b6d4'},\n     {nome:'PAR 4ch', ch:4, cor:'#22c55e'}]},\n];\n\nfunction overlaps(a,b){ return a.start <= b.start+b.ch-1 && b.start <= a.start+a.ch-1; }\n\nfunction Widget(){\n  const [phase,setPhase]=useState('intro');\n  const [ri,setRi]=useState(0);\n  const [starts,setStarts]=useState([]);\n  const [score,setScore]=useState(0);\n  const [fb,setFb]=useState(null);\n\n  const load=(idx)=>{ const r=ROUNDS[idx]; setStarts(r.fx.map((_,i)=>1)); setFb(null); };\n  const begin=()=>{ setScore(0); setRi(0); load(0); setPhase('play'); };\n\n  const fx = phase==='play'? ROUNDS[ri].fx.map((f,i)=>({...f,start:starts[i]||1})) : [];\n  // status de cada fixture\n  const status = fx.map((f,i)=>{\n    let conflito=false;\n    fx.forEach((o,j)=>{ if(i!==j && overlaps(f,o)) conflito=true; });\n    const fora = f.start+f.ch-1 > 512;\n    return conflito?'conflito': fora?'fora':'ok';\n  });\n  const todoOk = status.length>0 && status.every(s=>s==='ok');\n\n  const setStart=(i,v)=>{ v=Math.max(1,Math.min(512,v)); setStarts(s=>s.map((x,k)=>k===i?v:x)); setFb(null); };\n\n  const testar=()=>{\n    if(!todoOk){ setFb({ok:false,msg:'Ainda tem refletor em conflito (mesmo canal) ou fora do universo (>512).'}); return; }\n    // bônus de compactação: quanto menos canais \"gastos\" do 1 até o fim, melhor\n    const fim=Math.max(...fx.map(f=>f.start+f.ch-1));\n    const usados=fx.reduce((a,f)=>a+f.ch,0);\n    const compacto = fim===usados; // sem buracos e começando no 1\n    const pts = 100 + (compacto?60:0);\n    setScore(s=>s+pts);\n    setFb({ok:true, compacto, msg: compacto?'Perfeito e compacto! Tudo em sequência a partir do canal 1.':'Sem conflito — todos respondem! (dá pra deixar mais compacto, sem buracos)'});\n  };\n  const proximo=()=>{ if(ri>=ROUNDS.length-1){ setPhase('done'); return; } const n=ri+1; setRi(n); load(n); };\n\n  // auto-endereçar (mostra a lógica em sequência)\n  const auto=()=>{ let c=1; setStarts(fx.map(f=>{const s=c; c+=f.ch; return s;})); setFb(null); };\n\n  if(phase==='intro'){\n    return (\n      <div className=\"w-full h-full flex flex-col items-center justify-center text-center px-6\" style={{background:'#0b1120'}}>\n        <div className=\"text-amber-400 text-xs tracking-[0.3em] mb-2\">SMU PRO · LUZ BÁSICO</div>\n        <div className=\"text-white text-2xl font-bold mb-3\">🎛️ Endereçamento DMX</div>\n        <div className=\"text-slate-300 text-sm max-w-md mb-1\">Uma linha DMX (universo) tem <b className=\"text-amber-400\">512 canais</b>. Cada refletor ocupa um pedaço (ex: um PAR RGB+Dimmer usa <b>4 canais</b>).</div>\n        <div className=\"text-slate-300 text-sm max-w-md mb-5\">Você define o <b className=\"text-amber-400\">canal inicial</b> de cada um. Se dois ocuparem o mesmo canal, eles <b className=\"text-red-400\">brigam</b> e fazem a mesma coisa. Encaixe sem sobrepor.</div>\n        <button onClick={begin} className=\"px-7 py-3 rounded-xl bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold text-base transition\">▶ Começar</button>\n        <div className=\"text-slate-500 text-xs mt-4\">Regra de ouro: endereçar em sequência — 1, depois 5, depois 9…</div>\n      </div>\n    );\n  }\n  if(phase==='done'){\n    return (\n      <div className=\"w-full h-full flex flex-col items-center justify-center text-center px-6\" style={{background:'#0b1120'}}>\n        <div className=\"text-amber-400 text-sm mb-1\">Patch concluído</div>\n        <div className=\"text-white text-3xl font-bold mb-1\">{score} pontos</div>\n        <div className=\"text-slate-400 text-sm mb-5\">{score>=400?'Mão de LD! 🥇':score>=250?'Bom patch. 👏':'Lembre: cada fixture, seu pedaço de canais.'}</div>\n        <button onClick={begin} className=\"px-7 py-3 rounded-xl bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold transition\">↻ Jogar de novo</button>\n      </div>\n    );\n  }\n\n  const R=ROUNDS[ri];\n  return (\n    <div className=\"w-full h-full flex flex-col p-3 gap-2\" style={{background:'#0b1120'}}>\n      <div className=\"flex justify-between items-center text-xs\">\n        <span className=\"text-slate-200 font-bold\">PONTOS {score}</span>\n        <span className=\"text-amber-400 font-bold\">PATCH {ri+1}/{ROUNDS.length}</span>\n      </div>\n      <div className=\"text-center text-slate-300 text-sm\">{R.meta}</div>\n\n      {/* régua do universo DMX (1..64 visível, escala) */}\n      <div className=\"rounded-lg p-2\" style={{background:'#070b16'}}>\n        <div className=\"text-[10px] text-slate-500 mb-1\">UNIVERSO DMX — canais 1 a 64 (de 512)</div>\n        <div className=\"relative h-9 w-full rounded overflow-hidden\" style={{background:'#0f172a'}}>\n          {fx.map((f,i)=>{\n            const W=100/64;\n            const left=(f.start-1)*W, w=f.ch*W;\n            const bad=status[i]!=='ok';\n            return (\n              <div key={i} className=\"absolute top-0 h-full flex items-center justify-center text-[9px] font-bold\"\n                style={{left:left+'%', width:w+'%', background:bad?'rgba(239,68,68,0.85)':f.cor,\n                        border:'1px solid rgba(0,0,0,0.4)', color:'#0b1120',\n                        opacity: bad? 0.9:1}}>\n                {f.start}\n              </div>\n            );\n          })}\n          {/* marcas de 8 em 8 */}\n          {[8,16,24,32,40,48,56].map(n=>(\n            <div key={n} className=\"absolute top-0 h-full border-l border-slate-700/50\" style={{left:(n/64*100)+'%'}}></div>\n          ))}\n        </div>\n      </div>\n\n      {/* controles por fixture */}\n      <div className=\"flex-1 min-h-0 overflow-auto grid grid-cols-1 gap-1.5\">\n        {fx.map((f,i)=>{\n          const st=status[i];\n          return (\n            <div key={i} className=\"flex items-center gap-2 rounded-lg px-2 py-1.5\" style={{background:'#0f172a'}}>\n              <div className=\"w-3 h-7 rounded\" style={{background:f.cor}}></div>\n              <div className=\"flex-1 min-w-0\">\n                <div className=\"text-slate-200 text-xs font-bold truncate\">{f.nome}</div>\n                <div className=\"text-[10px] text-slate-500\">{f.ch} canais · usa {f.start}–{f.start+f.ch-1}</div>\n              </div>\n              <div className=\"flex items-center gap-1\">\n                <button onClick={()=>setStart(i,f.start-1)} className=\"w-7 h-7 rounded bg-slate-700 hover:bg-slate-600 text-white font-bold\">−</button>\n                <span className=\"w-10 text-center text-amber-300 font-bold tabular-nums\">{f.start}</span>\n                <button onClick={()=>setStart(i,f.start+1)} className=\"w-7 h-7 rounded bg-slate-700 hover:bg-slate-600 text-white font-bold\">+</button>\n              </div>\n              <div className=\"w-16 text-right text-[10px] font-bold\" style={{color: st==='ok'?'#22c55e':'#ef4444'}}>\n                {st==='ok'?'✓ responde': st==='fora'?'fora 512':'⚠ conflito'}\n              </div>\n            </div>\n          );\n        })}\n      </div>\n\n      {fb ? (\n        <div className=\"rounded-lg px-3 py-2 text-center\" style={{background:'#0f172a'}}>\n          <div className=\"text-sm\" style={{color:fb.ok?'#22c55e':'#fca5a5'}}>{fb.ok?(fb.compacto?'🥇 ':'✓ '):'⚠ '}{fb.msg}</div>\n          {fb.ok && <button onClick={proximo} className=\"mt-1 px-5 py-1.5 rounded-lg bg-amber-500 hover:bg-amber-400 text-slate-900 text-sm font-bold\">{ri>=ROUNDS.length-1?'Ver resultado':'Próximo patch →'}</button>}\n        </div>\n      ) : (\n        <div className=\"grid grid-cols-2 gap-2\">\n          <button onClick={auto} className=\"py-2 rounded-lg bg-slate-700 hover:bg-slate-600 text-white text-sm font-bold transition\">⚡ Auto (ver a lógica)</button>\n          <button onClick={testar} className=\"py-2 rounded-lg bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold transition\">Testar patch</button>\n        </div>\n      )}\n    </div>\n  );\n}\n\nReactDOM.createRoot(document.getElementById('root')).render(<Widget/>);\n</script>\n</body>\n</html>\n"
        }
      ]
    },
