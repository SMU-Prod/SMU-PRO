          "html": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>SMU PRO — Mixer de Cor (PAR LED)</title>\n<script src=\"https://unpkg.com/react@18/umd/react.production.min.js\"></script>\n<script src=\"https://unpkg.com/react-dom@18/umd/react-dom.production.min.js\"></script>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<script src=\"https://unpkg.com/@babel/standalone/babel.min.js\"></script>\n<style>html,body{height:100%;margin:0;background:#0b1120}#root{height:100vh}</style>\n</head>\n<body>\n<script>/*SMU-ZOOM*/(function(){var z=1,sc=null,MIN=1,MAX=2.5,STEP=0.25;function wrap(){if(sc)return;sc=document.createElement('div');sc.id='smu-sc';sc.style.transformOrigin='0 0';[].slice.call(document.body.children).filter(function(el){return (el.id||'').indexOf('smu-')!==0;}).forEach(function(k){sc.appendChild(k);});document.body.insertBefore(sc,document.body.firstChild);document.documentElement.style.overflow='auto';document.body.style.overflow='auto';document.body.style.margin='0';}function apply(){if(!sc)wrap();sc.style.transform='scale('+z+')';var w=sc.offsetWidth,h=sc.offsetHeight;document.body.style.width=(z>1?(w*z)+'px':'');document.body.style.height=(z>1?(h*z)+'px':'');var l=document.getElementById('smu-zl');if(l)l.textContent=Math.round(z*100)+'%';}function ui(){if(document.getElementById('smu-zoom'))return;var b=document.createElement('div');b.id='smu-zoom';b.style.cssText='position:fixed;left:10px;bottom:10px;z-index:99999;display:flex;align-items:center;gap:5px;background:#0e1420;border:1px solid #2c3340;border-radius:22px;padding:5px 8px;box-shadow:0 2px 10px rgba(0,0,0,.4);font-family:system-ui,sans-serif';function mk(t){var x=document.createElement('button');x.textContent=t;x.style.cssText='width:32px;height:32px;border-radius:50%;border:1px solid #2c3340;background:#171c26;color:#e5e7eb;font-size:18px;cursor:pointer;padding:0;line-height:1';return x;}var ic=document.createElement('span');ic.textContent='\\U0001F50D';ic.style.fontSize='14px';var mi=mk('−'),lab=document.createElement('span'),pl=mk('+');lab.id='smu-zl';lab.style.cssText='font-size:12px;color:#cbd5e1;min-width:44px;text-align:center;cursor:pointer';lab.textContent='100%';b.appendChild(ic);b.appendChild(mi);b.appendChild(lab);b.appendChild(pl);document.body.appendChild(b);mi.onclick=function(){z=Math.max(MIN,Math.round((z-STEP)*100)/100);apply();};pl.onclick=function(){z=Math.min(MAX,Math.round((z+STEP)*100)/100);apply();};lab.onclick=function(){z=1;apply();};}if(document.readyState!=='loading')ui();else document.addEventListener('DOMContentLoaded',ui);})();</script>\n\n<div id=\"root\"></div>\n<script type=\"text/babel\">\nconst {useState,useEffect,useRef} = React;\n\n// cores de palco que o \"diretor\" pode pedir (já incluem o brilho desejado)\nconst ALVOS = [\n  {nome:'Âmbar de balada', rgb:[255,140,25]},\n  {nome:'Azul meia-noite',  rgb:[25,45,165]},\n  {nome:'Magenta show',     rgb:[205,25,150]},\n  {nome:'Ciano gelo',       rgb:[30,205,215]},\n  {nome:'Vermelho sangue',  rgb:[185,12,12]},\n  {nome:'Verde neon',       rgb:[35,200,45]},\n  {nome:'Branco quente (meia luz)', rgb:[200,165,115]},\n  {nome:'Lavanda suave',    rgb:[150,120,220]},\n  {nome:'Laranja pôr do sol',rgb:[235,90,20]},\n];\n\nfunction dist(a,b){ return Math.sqrt((a[0]-b[0])**2+(a[1]-b[1])**2+(a[2]-b[2])**2); }\nfunction eff(r,g,b,dim){ const k=dim/255; return [Math.round(r*k),Math.round(g*k),Math.round(b*k)]; }\nconst css = a => `rgb(${a[0]},${a[1]},${a[2]})`;\n\nfunction Slider({label,ch,color,val,set}){\n  return (\n    <div>\n      <div className=\"flex justify-between text-xs mb-1\">\n        <span className=\"font-bold\" style={{color}}>{ch} · {label}</span>\n        <span className=\"text-slate-400 tabular-nums\">{val}</span>\n      </div>\n      <input type=\"range\" min=\"0\" max=\"255\" value={val}\n        onChange={e=>set(+e.target.value)}\n        className=\"w-full h-2 rounded-lg appearance-none cursor-pointer\"\n        style={{accentColor:color, background:`linear-gradient(90deg, ${color} ${val/255*100}%, #1e293b ${val/255*100}%)`}}/>\n    </div>\n  );\n}\n\nfunction Widget(){\n  const [phase,setPhase]=useState('intro'); // intro | play | done\n  const [r,setR]=useState(120),[g,setG]=useState(120),[b,setB]=useState(120),[dim,setDim]=useState(200);\n  const [round,setRound]=useState(1);\n  const [score,setScore]=useState(0);\n  const [alvo,setAlvo]=useState(ALVOS[0]);\n  const [fb,setFb]=useState(null);   // {stars,msg,hint}\n  const usados=useRef([]);\n\n  const novoAlvo=()=>{\n    let pool=ALVOS.map((_,i)=>i).filter(i=>!usados.current.includes(i));\n    if(!pool.length){ usados.current=[]; pool=ALVOS.map((_,i)=>i); }\n    const i=pool[Math.floor(Math.random()*pool.length)];\n    usados.current.push(i); setAlvo(ALVOS[i]);\n  };\n  const begin=()=>{ usados.current=[]; setScore(0); setRound(1); setFb(null);\n    setR(120);setG(120);setB(120);setDim(200); novoAlvo(); setPhase('play'); };\n\n  const minha = eff(r,g,b,dim);\n  const conferir=()=>{\n    const d=dist(minha, alvo.rgb);\n    let stars,msg,pts;\n    if(d<28){stars=3;msg='Perfeito! Cor no ponto.';pts=100;}\n    else if(d<65){stars=2;msg='Quase lá — bem próximo.';pts=60;}\n    else if(d<120){stars=1;msg='Deu pra reconhecer, mas ajuste fino faltou.';pts=30;}\n    else{stars=0;msg='Longe. Olhe qual canal está sobrando ou faltando.';pts=0;}\n    // dica de qual canal corrigir\n    const nm=['Vermelho','Verde','Azul']; let hint='';\n    if(stars<3){\n      let worst=0,wd=0; for(let k=0;k<3;k++){const dd=minha[k]-alvo.rgb[k]; if(Math.abs(dd)>Math.abs(wd)){wd=dd;worst=k;}}\n      hint = wd>0 ? `Tente MENOS ${nm[worst].toLowerCase()}` : `Tente MAIS ${nm[worst].toLowerCase()}`;\n      const bri = (minha[0]+minha[1]+minha[2]) - (alvo.rgb[0]+alvo.rgb[1]+alvo.rgb[2]);\n      if(Math.abs(bri)>120) hint += bri>0?' · e abaixe o Dimmer':' · e suba o Dimmer';\n    }\n    setScore(s=>s+pts);\n    setFb({stars,msg,hint});\n  };\n  const proximo=()=>{\n    if(round>=6){ setPhase('done'); return; }\n    setRound(round+1); setFb(null); novoAlvo();\n  };\n\n  // ===== TELAS =====\n  if(phase==='intro'){\n    return (\n      <div className=\"w-full h-full flex flex-col items-center justify-center text-center px-6\" style={{background:'#0b1120'}}>\n        <div className=\"text-amber-400 text-xs tracking-[0.3em] mb-2\">SMU PRO · LUZ BÁSICO</div>\n        <div className=\"text-white text-2xl font-bold mb-3\">🎨 Mixer de Cor — PAR LED</div>\n        <div className=\"text-slate-300 text-sm max-w-md mb-1\">Um refletor LED faz cor misturando <b className=\"text-red-400\">Vermelho</b> + <b className=\"text-green-400\">Verde</b> + <b className=\"text-blue-400\">Azul</b> (mistura aditiva). Cada cor é um <b>canal DMX</b>.</div>\n        <div className=\"text-slate-300 text-sm max-w-md mb-5\">O diretor pede uma cor. Mexa os canais e o <b className=\"text-amber-400\">Dimmer</b> (brilho) até acertar. Quanto mais perto, mais pontos.</div>\n        <button onClick={begin} className=\"px-7 py-3 rounded-xl bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold text-base transition\">▶ Começar</button>\n        <div className=\"text-slate-500 text-xs mt-4\">R+G=amarelo · R+B=magenta · G+B=ciano · tudo no máximo=branco</div>\n      </div>\n    );\n  }\n  if(phase==='done'){\n    return (\n      <div className=\"w-full h-full flex flex-col items-center justify-center text-center px-6\" style={{background:'#0b1120'}}>\n        <div className=\"text-amber-400 text-sm mb-1\">Fim da sessão de luz</div>\n        <div className=\"text-white text-3xl font-bold mb-1\">{score} pontos</div>\n        <div className=\"text-slate-400 text-sm mb-5\">{score>=480?'Olho de LD! 🥇':score>=300?'Boa mistura de cor. 👏':'Treine o olho pras cores de palco.'}</div>\n        <button onClick={begin} className=\"px-7 py-3 rounded-xl bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold transition\">↻ Jogar de novo</button>\n      </div>\n    );\n  }\n\n  // play\n  return (\n    <div className=\"w-full h-full flex flex-col p-3 gap-2\" style={{background:'#0b1120'}}>\n      {/* HUD */}\n      <div className=\"flex justify-between items-center text-xs\">\n        <span className=\"text-slate-200 font-bold\">PONTOS {score}</span>\n        <span className=\"text-amber-400 font-bold\">ROUND {round}/6</span>\n      </div>\n\n      {/* palco: refletor + alvo */}\n      <div className=\"flex-1 min-h-0 grid grid-cols-2 gap-3\">\n        {/* meu refletor */}\n        <div className=\"rounded-xl border border-slate-700/40 flex flex-col items-center justify-center relative overflow-hidden\" style={{background:'#070b16'}}>\n          <div className=\"absolute top-2 left-0 right-0 text-center text-[10px] text-slate-400\">SEU REFLETOR</div>\n          {/* feixe */}\n          <svg viewBox=\"0 0 120 150\" className=\"w-full h-full\" preserveAspectRatio=\"xMidYMid meet\">\n            <defs>\n              <radialGradient id=\"beam\" cx=\"50%\" cy=\"18%\" r=\"80%\">\n                <stop offset=\"0%\" stopColor={css(minha)} stopOpacity=\"0.95\"/>\n                <stop offset=\"55%\" stopColor={css(minha)} stopOpacity=\"0.35\"/>\n                <stop offset=\"100%\" stopColor={css(minha)} stopOpacity=\"0\"/>\n              </radialGradient>\n            </defs>\n            {/* corpo do PAR */}\n            <rect x=\"48\" y=\"8\" width=\"24\" height=\"16\" rx=\"3\" fill=\"#1e293b\" stroke=\"#334155\"/>\n            <ellipse cx=\"60\" cy=\"24\" rx=\"13\" ry=\"4\" fill={css(minha)} stroke=\"#334155\"/>\n            {/* feixe de luz */}\n            <path d=\"M47 26 L18 142 L102 142 L73 26 Z\" fill=\"url(#beam)\"/>\n            {/* poça de luz no chão */}\n            <ellipse cx=\"60\" cy=\"142\" rx=\"42\" ry=\"7\" fill={css(minha)} opacity=\"0.55\"/>\n          </svg>\n        </div>\n        {/* alvo pedido */}\n        <div className=\"rounded-xl border border-slate-700/40 flex flex-col items-center justify-center p-2\" style={{background:'#070b16'}}>\n          <div className=\"text-[10px] text-slate-400 mb-2\">O DIRETOR PEDIU</div>\n          <div className=\"w-24 h-24 rounded-full shadow-lg\" style={{background:css(alvo.rgb), boxShadow:`0 0 36px ${css(alvo.rgb)}`}}></div>\n          <div className=\"text-white text-sm font-bold mt-3 text-center\">{alvo.nome}</div>\n        </div>\n      </div>\n\n      {/* canais */}\n      <div className=\"grid grid-cols-2 gap-x-4 gap-y-2 px-1\">\n        <Slider label=\"Vermelho\" ch=\"CH1\" color=\"#ef4444\" val={r} set={setR}/>\n        <Slider label=\"Verde\"    ch=\"CH2\" color=\"#22c55e\" val={g} set={setG}/>\n        <Slider label=\"Azul\"     ch=\"CH3\" color=\"#3b82f6\" val={b} set={setB}/>\n        <Slider label=\"Dimmer\"   ch=\"CH4\" color=\"#e8e1d0\" val={dim} set={setDim}/>\n      </div>\n\n      {/* feedback / ação */}\n      {fb ? (\n        <div className=\"rounded-lg px-3 py-2 text-center\" style={{background:'#0f172a'}}>\n          <div className=\"text-lg\">{'★'.repeat(fb.stars)}<span className=\"text-slate-700\">{'★'.repeat(3-fb.stars)}</span></div>\n          <div className=\"text-slate-200 text-xs\">{fb.msg}{fb.hint && <span className=\"text-amber-300\"> — {fb.hint}</span>}</div>\n          <button onClick={proximo} className=\"mt-1 px-5 py-1.5 rounded-lg bg-amber-500 hover:bg-amber-400 text-slate-900 text-sm font-bold\">{round>=6?'Ver resultado':'Próxima cor →'}</button>\n        </div>\n      ) : (\n        <button onClick={conferir} className=\"py-2.5 rounded-lg bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold transition\">Conferir cor</button>\n      )}\n    </div>\n  );\n}\n\nReactDOM.createRoot(document.getElementById('root')).render(<Widget/>);\n</script>\n</body>\n</html>\n"
        }
      ]
    },
