          "html": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>SMU PRO — Iluminação de 3 Pontos</title>\n<script src=\"https://unpkg.com/react@18/umd/react.production.min.js\"></script>\n<script src=\"https://unpkg.com/react-dom@18/umd/react-dom.production.min.js\"></script>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<script src=\"https://unpkg.com/@babel/standalone/babel.min.js\"></script>\n<style>html,body{height:100%;margin:0;background:#0b1120}#root{height:100vh}</style>\n</head>\n<body>\n<script>/*SMU-ZOOM*/(function(){var z=1,sc=null,MIN=1,MAX=2.5,STEP=0.25;function wrap(){if(sc)return;sc=document.createElement('div');sc.id='smu-sc';sc.style.transformOrigin='0 0';[].slice.call(document.body.children).filter(function(el){return (el.id||'').indexOf('smu-')!==0;}).forEach(function(k){sc.appendChild(k);});document.body.insertBefore(sc,document.body.firstChild);document.documentElement.style.overflow='auto';document.body.style.overflow='auto';document.body.style.margin='0';}function apply(){if(!sc)wrap();sc.style.transform='scale('+z+')';var w=sc.offsetWidth,h=sc.offsetHeight;document.body.style.width=(z>1?(w*z)+'px':'');document.body.style.height=(z>1?(h*z)+'px':'');var l=document.getElementById('smu-zl');if(l)l.textContent=Math.round(z*100)+'%';}function ui(){if(document.getElementById('smu-zoom'))return;var b=document.createElement('div');b.id='smu-zoom';b.style.cssText='position:fixed;left:10px;bottom:10px;z-index:99999;display:flex;align-items:center;gap:5px;background:#0e1420;border:1px solid #2c3340;border-radius:22px;padding:5px 8px;box-shadow:0 2px 10px rgba(0,0,0,.4);font-family:system-ui,sans-serif';function mk(t){var x=document.createElement('button');x.textContent=t;x.style.cssText='width:32px;height:32px;border-radius:50%;border:1px solid #2c3340;background:#171c26;color:#e5e7eb;font-size:18px;cursor:pointer;padding:0;line-height:1';return x;}var ic=document.createElement('span');ic.textContent='\\U0001F50D';ic.style.fontSize='14px';var mi=mk('−'),lab=document.createElement('span'),pl=mk('+');lab.id='smu-zl';lab.style.cssText='font-size:12px;color:#cbd5e1;min-width:44px;text-align:center;cursor:pointer';lab.textContent='100%';b.appendChild(ic);b.appendChild(mi);b.appendChild(lab);b.appendChild(pl);document.body.appendChild(b);mi.onclick=function(){z=Math.max(MIN,Math.round((z-STEP)*100)/100);apply();};pl.onclick=function(){z=Math.min(MAX,Math.round((z+STEP)*100)/100);apply();};lab.onclick=function(){z=1;apply();};}if(document.readyState!=='loading')ui();else document.addEventListener('DOMContentLoaded',ui);})();</script>\n\n<div id=\"root\"></div>\n<script type=\"text/babel\">\nconst {useState} = React;\n\nconst LOOKS = [\n  {nome:'Retrato equilibrado',        key:85, fill:55, back:45, dica:'Rosto claro, sombra suave, leve contorno atrás.'},\n  {nome:'Contraluz dramático (silhueta)', key:25, fill:18, back:95, dica:'Pouca luz no rosto, forte recorte atrás.'},\n  {nome:'Corporativo / telejornal',   key:90, fill:82, back:30, dica:'Tudo claro, quase sem sombra (chapado).'},\n  {nome:'Film noir (sombra dura)',    key:92, fill:10, back:35, dica:'Um lado aceso, o outro na sombra forte.'},\n];\n\nconst SKIN=[232,194,156];\nconst clamp=(v,a,b)=>Math.max(a,Math.min(b,v));\nconst scale=(c,k)=>`rgb(${Math.round(clamp(c[0]*k,0,255))},${Math.round(clamp(c[1]*k,0,255))},${Math.round(clamp(c[2]*k,0,255))})`;\n\nfunction Slider({label,emoji,color,val,set}){\n  return (\n    <div>\n      <div className=\"flex justify-between text-xs mb-1\">\n        <span className=\"font-bold text-slate-200\">{emoji} {label}</span>\n        <span className=\"text-slate-400 tabular-nums\">{val}%</span>\n      </div>\n      <input type=\"range\" min=\"0\" max=\"100\" value={val} onChange={e=>set(+e.target.value)}\n        className=\"w-full h-2 rounded-lg appearance-none cursor-pointer\"\n        style={{accentColor:color, background:`linear-gradient(90deg, ${color} ${val}%, #1e293b ${val}%)`}}/>\n    </div>\n  );\n}\n\n// desenho do rosto reagindo às 3 luzes\nfunction Palco({k,f,b}){\n  const litB    = 0.12 + k/100*0.95;            // lado iluminado pela Key\n  const shadowB = 0.12 + f/100*0.62 + k/100*0.08; // lado de sombra (levantado pelo Fill)\n  const lit=scale(SKIN,litB), sh=scale(SKIN,shadowB);\n  const rim = b/100;                            // contorno (Back)\n  const floorOp = clamp((k/100)*(1 - f/100)*0.6, 0, 0.6); // sombra no chão: mais Fill = mais suave\n  return (\n    <svg viewBox=\"0 0 200 170\" className=\"w-full h-full\" preserveAspectRatio=\"xMidYMid meet\">\n      <defs>\n        <linearGradient id=\"face\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n          <stop offset=\"0%\"  stopColor={lit}/>\n          <stop offset=\"48%\" stopColor={lit}/>\n          <stop offset=\"100%\" stopColor={sh}/>\n        </linearGradient>\n        <radialGradient id=\"glow\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n          <stop offset=\"60%\" stopColor=\"rgba(150,190,255,0)\"/>\n          <stop offset=\"100%\" stopColor={`rgba(150,190,255,${rim*0.55})`}/>\n        </radialGradient>\n      </defs>\n      {/* fundo */}\n      <rect x=\"0\" y=\"0\" width=\"200\" height=\"170\" fill=\"#070b16\"/>\n      {/* glow do contraluz atrás da cabeça */}\n      <ellipse cx=\"100\" cy=\"74\" rx=\"60\" ry=\"68\" fill=\"url(#glow)\"/>\n      {/* sombra no chão */}\n      <ellipse cx=\"118\" cy=\"150\" rx=\"44\" ry=\"8\" fill=\"#000\" opacity={floorOp}/>\n      {/* pescoço */}\n      <rect x=\"88\" y=\"118\" width=\"24\" height=\"26\" rx=\"6\" fill={scale(SKIN,(litB+shadowB)/2*0.8)}/>\n      {/* cabeça */}\n      <ellipse cx=\"100\" cy=\"74\" rx=\"40\" ry=\"50\" fill=\"url(#face)\"\n        stroke={`rgba(190,215,255,${rim})`} strokeWidth={1+rim*4}/>\n      {/* cabelo (topo) recebe rim */}\n      <path d=\"M62 60 Q100 18 138 60 Q120 44 100 44 Q80 44 62 60Z\" fill={scale([40,34,30],0.5+litB*0.4)}\n        stroke={`rgba(190,215,255,${rim})`} strokeWidth={rim*3}/>\n      {/* traços simples do rosto (lado iluminado) */}\n      <circle cx=\"86\" cy=\"70\" r=\"3\" fill=\"#1f2937\" opacity={0.5+litB*0.4}/>\n      <circle cx=\"112\" cy=\"70\" r=\"3\" fill=\"#1f2937\" opacity={0.3+shadowB*0.5}/>\n      <path d=\"M92 96 Q100 102 108 96\" stroke=\"#7c4a36\" strokeWidth=\"2\" fill=\"none\" opacity={0.4+litB*0.4}/>\n    </svg>\n  );\n}\n\nfunction Widget(){\n  const [phase,setPhase]=useState('intro');\n  const [k,setK]=useState(50),[f,setF]=useState(50),[b,setB]=useState(50);\n  const [ri,setRi]=useState(0);\n  const [score,setScore]=useState(0);\n  const [fb,setFb]=useState(null);\n\n  const begin=()=>{ setScore(0); setRi(0); setK(50);setF(50);setB(50); setFb(null); setPhase('play'); };\n  const look=LOOKS[ri];\n\n  const conferir=()=>{\n    const d=Math.sqrt((k-look.key)**2+(f-look.fill)**2+(b-look.back)**2);\n    let stars,msg,pts;\n    if(d<18){stars=3;msg='Foto pronta! Foco no ponto.';pts=100;}\n    else if(d<38){stars=2;msg='Muito perto do look pedido.';pts=60;}\n    else if(d<66){stars=1;msg='Dá pra entender, mas falta ajuste.';pts=30;}\n    else{stars=0;msg='Longe do look. Veja qual luz está sobrando/faltando.';pts=0;}\n    let hint='';\n    if(stars<3){\n      const dif=[['Key',k-look.key],['Fill',f-look.fill],['Contraluz',b-look.back]].sort((a,b)=>Math.abs(b[1])-Math.abs(a[1]))[0];\n      hint = dif[1]>0?`Diminua a ${dif[0]}`:`Aumente a ${dif[0]}`;\n    }\n    setScore(s=>s+pts); setFb({stars,msg,hint});\n  };\n  const proximo=()=>{ if(ri>=LOOKS.length-1){ setPhase('done'); return; } setRi(ri+1); setFb(null); setK(50);setF(50);setB(50); };\n\n  if(phase==='intro'){\n    return (\n      <div className=\"w-full h-full flex flex-col items-center justify-center text-center px-6\" style={{background:'#0b1120'}}>\n        <div className=\"text-amber-400 text-xs tracking-[0.3em] mb-2\">SMU PRO · LUZ BÁSICO</div>\n        <div className=\"text-white text-2xl font-bold mb-3\">💡 Iluminação de 3 Pontos</div>\n        <div className=\"text-slate-300 text-sm max-w-md mb-1\">A base de iluminar qualquer pessoa: <b className=\"text-amber-300\">Key</b> (luz principal), <b className=\"text-sky-300\">Fill</b> (clareia a sombra) e <b className=\"text-fuchsia-300\">Contraluz</b> (separa do fundo).</div>\n        <div className=\"text-slate-300 text-sm max-w-md mb-5\">O diretor descreve o <b>look</b>. Ajuste as três luzes e veja o rosto mudar ao vivo até chegar lá.</div>\n        <button onClick={begin} className=\"px-7 py-3 rounded-xl bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold text-base transition\">▶ Começar</button>\n        <div className=\"text-slate-500 text-xs mt-4\">Muito Fill = chapado · pouco Fill = dramático · Contraluz dá o contorno</div>\n      </div>\n    );\n  }\n  if(phase==='done'){\n    return (\n      <div className=\"w-full h-full flex flex-col items-center justify-center text-center px-6\" style={{background:'#0b1120'}}>\n        <div className=\"text-amber-400 text-sm mb-1\">Sessão de foto encerrada</div>\n        <div className=\"text-white text-3xl font-bold mb-1\">{score} pontos</div>\n        <div className=\"text-slate-400 text-sm mb-5\">{score>=320?'Diretor de fotografia! 🥇':score>=200?'Bom olho de luz. 👏':'Treine: Key acende, Fill suaviza, Contraluz recorta.'}</div>\n        <button onClick={begin} className=\"px-7 py-3 rounded-xl bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold transition\">↻ Jogar de novo</button>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"w-full h-full flex flex-col p-3 gap-2\" style={{background:'#0b1120'}}>\n      <div className=\"flex justify-between items-center text-xs\">\n        <span className=\"text-slate-200 font-bold\">PONTOS {score}</span>\n        <span className=\"text-amber-400 font-bold\">LOOK {ri+1}/{LOOKS.length}</span>\n      </div>\n      <div className=\"text-center text-slate-200 text-sm\">O diretor pediu: <b className=\"text-amber-300\">{look.nome}</b></div>\n      <div className=\"text-center text-slate-500 text-[11px] -mt-1\">{look.dica}</div>\n\n      <div className=\"flex-1 min-h-0 rounded-xl overflow-hidden border border-slate-700/40\">\n        <Palco k={k} f={f} b={b}/>\n      </div>\n\n      <div className=\"grid grid-cols-1 gap-2 px-1\">\n        <Slider label=\"Key (principal)\" emoji=\"🔆\" color=\"#f59e0b\" val={k} set={setK}/>\n        <Slider label=\"Fill (suaviza sombra)\" emoji=\"🌥️\" color=\"#38bdf8\" val={f} set={setF}/>\n        <Slider label=\"Contraluz (recorte)\" emoji=\"✨\" color=\"#d946ef\" val={b} set={setB}/>\n      </div>\n\n      {fb ? (\n        <div className=\"rounded-lg px-3 py-2 text-center\" style={{background:'#0f172a'}}>\n          <div className=\"text-lg\">{'★'.repeat(fb.stars)}<span className=\"text-slate-700\">{'★'.repeat(3-fb.stars)}</span></div>\n          <div className=\"text-slate-200 text-xs\">{fb.msg}{fb.hint && <span className=\"text-amber-300\"> — {fb.hint}</span>}</div>\n          <button onClick={proximo} className=\"mt-1 px-5 py-1.5 rounded-lg bg-amber-500 hover:bg-amber-400 text-slate-900 text-sm font-bold\">{ri>=LOOKS.length-1?'Ver resultado':'Próximo look →'}</button>\n        </div>\n      ) : (\n        <button onClick={conferir} className=\"py-2.5 rounded-lg bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold transition\">📸 Conferir o look</button>\n      )}\n    </div>\n  );\n}\n\nReactDOM.createRoot(document.getElementById('root')).render(<Widget/>);\n</script>\n</body>\n</html>\n"
        }
      ]
    }
  ]
}