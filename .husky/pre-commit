npx lint-staged

# ── Tradutor interno (i18n) ──────────────────────────────────────────────
# Ao commitar, preenche automaticamente as traduções EN/ES que faltarem na
# interface. Se OPENAI_API_KEY estiver disponível, traduz e inclui o arquivo
# gerado no commit; senão, apenas avisa. Nunca bloqueia o commit.
if node scripts/i18n-sync.mjs; then
  git add src/lib/i18n/dict.generated.ts 2>/dev/null || true
else
  echo "[i18n] aviso: ha strings de interface sem traducao. Rode 'npm run i18n:sync' com OPENAI_API_KEY para preencher."
fi
true
